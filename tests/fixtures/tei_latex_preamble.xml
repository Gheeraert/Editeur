      <!-- Paragraphes orphelins avant tout <div> : avant-propos sans titre de section -->
      <p>Premier paragraphe de l'avant-propos.</p>
      <p>Deuxième paragraphe de l'avant-propos.</p>
      <!-- Premier vrai chapitre : crée un <div> -->
      <div type="section1">
        <head>Chapitre 1</head>
        <p>Contenu du chapitre 1.</p>
      </div>
    </body>
