# Configuration IA — PURH Editorial
# Copier ce fichier vers `.env` puis renseigner la clé du provider choisi.

# ── Provider actif ─────────────────────────────────────────────────────────
# "groq"      → rapide, quasi-gratuit (free tier), bon pour classification
# "anthropic" → meilleur français, ~0.016$/manuscrit, recommandé pour l'éditorial
PURH_AI_PROVIDER=groq

# ── Groq (OpenAI-compatible) ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=20
GROQ_MAX_BLOCKS=3

# ── Anthropic (provider natif) ─────────────────────────────────────────────
# Modèles recommandés :
#   claude-haiku-4-5-20251001  → ~$0.016/manuscrit, excellent français, rapide
#   claude-sonnet-4-6          → ~$0.057/manuscrit, qualité maximale
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
